---
layout: page
title: Lego
permalink: /collections/lego/
---

<h2>Lego Collection</h2>

<p>
  <strong>{{ lego.stats.ownedCount }}</strong> owned ·
  <strong>{{ lego.stats.wantedCount }}</strong> wanted ·
  <strong>{{ lego.stats.ownedPieces }}</strong> pieces (owned) ·
  <strong>{{ lego.stats.builtCount }}</strong> built ·
  <strong>{{ lego.stats.unbuiltCount }}</strong> unbuilt
</p>

<h3>Owned</h3>

{% if lego.themesOwned and lego.themesOwned.length %}
  <p>
    Themes:
    {% for t in lego.themesOwned %}
      <a href="#theme-owned-{{ t | slug }}">{{ t }}</a>{% if not loop.last %} · {% endif %}
    {% endfor %}
  </p>
{% endif %}

{% for theme, sets in lego.byThemeOwned %}
  <h4 id="theme-owned-{{ theme | slug }}">{{ theme }}</h4>

  <div class="media-grid">
    {% for s in sets %}
      <article class="media-card">
        <div class="media-thumb u-p-1 u-pb-0">
          {% if s.image %}
            {% if s.url %}<a href="{{ s.url }}" aria-label="{{ s.setNumber }} {{ s.name }}">{% endif %}
              <img src="{{ s.image }}" alt="{{ s.setNumber }} {{ s.name }}" loading="lazy">
            {% if s.url %}</a>{% endif %}
          {% else %}
            <span class="media-meta">No image</span>
          {% endif %}
        </div>

        <div class="media-body">
          <p class="media-title">
            {% if s.url %}
              <a href="{{ s.url }}">
                {{ s.setNumber or "Set" }} — {{ s.name or "Unknown set" }}
              </a>
            {% else %}
              {{ s.setNumber or "Set" }} — {{ s.name or "Unknown set" }}
            {% endif %}
          </p>

          <p class="media-meta">
            {% if s.year %}{{ s.year }}{% else %}Year unknown{% endif %}
            {% if s.pieces %} · {{ s.pieces }} pcs{% endif %}
          </p>

          {% if s.qtyOwned or s.subtheme %}
          <div class="media-badges">
            {% if s.qtyOwned and s.qtyOwned > 1 %}
              <span class="media-badge">Qty owned: {{ s.qtyOwned }}</span>
            {% endif %}
            {% if s.subtheme %}
              <span class="media-badge">{{ s.subtheme }}</span>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
{% endfor %}

<h3>Wanted</h3>

{% if lego.wanted.length == 0 %}
  <p>Nothing on the wanted list right now.</p>
{% endif %}

{% for theme, sets in lego.byThemeWanted %}
  <h4>{{ theme }}</h4>

  <div class="media-grid">
    {% for s in sets %}
      <article class="media-card">
        <div class="media-thumb">
          {% if s.image %}
            {% if s.url %}<a href="{{ s.url }}" aria-label="{{ s.setNumber }} {{ s.name }}">{% endif %}
              <img src="{{ s.image }}" alt="{{ s.setNumber }} {{ s.name }}" loading="lazy">
            {% if s.url %}</a>{% endif %}
          {% else %}
            <span class="media-meta">No image</span>
          {% endif %}
        </div>

        <div class="media-body">
          <p class="media-title">
            {% if s.url %}
            <a href="{{ s.url }}">
              {{ s.setNumber or "Set" }} — {{ s.name or "Unknown set" }}
            </a>
            {% else %}
              {{ s.setNumber or "Set" }} — {{ s.name or "Unknown set" }}
            {% endif %}
          </p>

          <p class="media-meta">
            {% if s.year %}{{ s.year }}{% else %}Year unknown{% endif %}
            {% if s.pieces %} · {{ s.pieces }} pcs{% endif %}
          </p>

          {% if s.qtyWanted or s.subtheme %}
          <div class="media-badges">
            {% if s.qtyWanted and s.qtyWanted > 1 %}
              <span class="badge">Qty wanted: {{ s.qtyWanted }}</span>
            {% endif %}
            {% if s.subtheme %}
              <span class="badge">{{ s.subtheme }}</span>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
{% endfor %}
