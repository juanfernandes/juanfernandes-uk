---
layout: page
title: Games
permalink: /collections/games/
---

<h2>Collection</h2>

<p>
  <strong>{{ games.stats.ownedCount }}</strong> owned ·
  <strong>{{ games.stats.wantedCount }}</strong> wanted ·
  <strong>{{ games.stats.platformsCount }}</strong> platforms ·
  <strong>{{ games.stats.playingCount }}</strong> playing ·
  <strong>{{ games.stats.unplayedCount }}</strong> unplayed ·
  <strong>{{ games.stats.completedCount }}</strong> completed
</p>

<h3>Owned</h3>

{% if games.platforms and games.platforms.length %}
  <div class="platform-nav">
    <p>
      <strong>Platforms:</strong>
    {% for p in games.platforms %}
      <a href="#platform-{{ p | slug }}">{{ p }}</a>{% if not loop.last %} · {% endif %}
    {% endfor %}
    </p>
  </div>
{% endif %}

{% for platform, items in games.byPlatform %}
  <h4 id="platform-{{ platform | slug }}">{{ platform }}</h4>

  <div class="media-grid">
    {% for g in items %}
      <article class="media-card">
        <div class="media-thumb">
          {% if g.cover %}
            {% if g.url %}<a href="{{ g.url }}" aria-label="{{ g.title }}">{% endif %}
              <img src="{{ g.cover }}" alt="{{ g.title }} cover" loading="lazy">
            {% if g.url %}</a>{% endif %}
          {% else %}
            <span class="media-meta">No cover</span>
          {% endif %}
        </div>

        <div class="media-body">
          <p class="media-title">
            {% if g.url %}
              <a href="{{ g.url }}">{{ g.title }}</a>
            {% else %}
              {{ g.title }}
            {% endif %}
          </p>

          <p class="media-meta">
            {% if g.releaseYear %}{{ g.releaseYear }}{% endif %}
          </p>

          <div class="media-badges">
            <span class="badge">{{ g.playStatus }}</span>
          </div>

          {% if g.notes %}
            <p class="media-meta" style="margin-top:.6rem">{{ g.notes }}</p>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
{% endfor %}

<h3>Wanted</h3>

{% if games.wanted.length == 0 %}
  <p>Nothing on the wanted list right now.</p>
{% endif %}

{% if games.platformsWanted and games.platformsWanted.length %}
  <div class="platform-nav">
    <p>
      <strong>Platforms:</strong>
      {% for p in games.platformsWanted %}
        <a href="#platform-wanted-{{ p | slug }}">{{ p }}</a>{% if not loop.last %} · {% endif %}
      {% endfor %}
    </p>
  </div>
{% endif %}

{% for platform, items in games.byPlatformWanted %}
  <h4 id="platform-wanted-{{ platform | slug }}">{{ platform }}</h4>
  <ul>
    {% for g in items %}
      <li>
        {% if g.url %}<a href="{{ g.url }}">{{ g.title }}</a>{% else %}{{ g.title }}{% endif %}
        {% if g.releaseYear %} ({{ g.releaseYear }}){% endif %}
      </li>
    {% endfor %}
  </ul>
{% endfor %}
