{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<p>
  Years:
  {% for y in watch.years %}
    {% if watch.moviesByYear[y] %}<a href="/logs/watching/films/{{ y }}/">{{ y }}</a>{% if not loop.last %} · {% endif %}{% endif %}
  {% endfor %}
</p>

<div class="media-grid">
  {% for film in watch.movies %}
    {% set item = film %}
    {% include "partials/media-card.njk" %}
  {% endfor %}
</div>

