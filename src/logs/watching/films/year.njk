---
layout: page
pagination:
  data: watch.movieYears
  size: 1
  alias: year
permalink: "/logs/watching/films/{{ year }}/"
eleventyComputed:
  title: "Films — {{ year }}"
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<h2>Films watched in {{ year }}</h2>

<p>A year-by-year view of the films I watched in {{ year }}.</p>

<p class="dash-kpis">This year I've watched <strong>{{ (watch.movieStatsByYear[year] and watch.movieStatsByYear[year].films) or 0 }}</strong> films.</p>

{% if watch.movieYears and watch.movieYears.length %}
<div class="media-years">
  <span>Years:</span>
  {% for y in watch.movieYears %}
    <a href="/logs/watching/films/{{ y }}/">{{ y }}</a>{% if not loop.last %} · {% endif %}
  {% endfor %}
</div>
{% endif %}

<div class="media-grid">
  {% for item in (watch.moviesByYear[year] or []) %}
    {% include "partials/media-card.njk" %}
  {% endfor %}
</div>

{% include "components/tmdb-attribution.njk" %}
