---
layout: page
title: Watching
permalink: /logs/watching/
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A log of the films and television I’ve watched — from single movie nights to full seasons of shows. It tracks when I watched them, what stood out, and occasionally how much I enjoyed them.</p>

    {% set latestFilm = watch.movies[0] %}
    {% set latestEp = watch.tvEpisodes[0] %}

    <div class="media-grid media-grid--2-col">
      <section class="media-card">
        <div class="media-card__body">
          <h2 class="media-card__heading"><a href="/logs/watching/films/">Films</a></h2>
          <p class="media-card__muted">Latest films and quick year browsing.</p>

          <div class="media-card__latest">
            <h3>Latest film</h3>
            {% if latestFilm %}
              <div class="media-card__header">
              {% if latestFilm.poster %}
                <img
                  src="{{ latestFilm.poster }}"
                  alt="Poster for {{ latestFilm.title }}"
                  loading="lazy"
                  class="media-card__poster media-card__poster-3-3"
                >
              {% endif %}
                <div>
                  <h4 class="media-card__title">
                    {% if latestFilm.tmdbUrl %}
                      <a href="{{ latestFilm.tmdbUrl }}" target="_blank" rel="noopener">{{ latestFilm.title }}</a>
                    {% if latestFilm.year %}<span class="media-card__muted"> ({{ latestFilm.year }})</span>{% endif %}
                    {% else %}
                      {{ latestFilm.title }}  {% if latestFilm.year %}<span class="media-card__muted"> ({{ latestFilm.year }})</span>{% endif %}
                    {% endif %}
                  </h4>
                  <div class="media-card__meta">
                    {% if latestFilm.watchedOn %}
                    <span>Watched on: {{ latestFilm.watchedOn | dateFilter }}</span>
                    {% endif %}

                    {% if latestFilm.rating %}
                    <span>Rated: ★ {{ latestFilm.rating }}/5</span>
                    {% endif %}

                    {% if latestFilm.rewatch %}
                    <span class="tag">Rewatch</span>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% else %}
              <p class="media-card__muted">No films logged yet.</p>
            {% endif %}
          </div>

          <div class="media-card__links">
            <a href="/logs/watching/films/">Browse all films →</a>
          </div>
        </div>
      </section>

      <section class="media-card">
        <div class="media-card__body">
          <h2 class="media-card__heading"><a href="/logs/watching/tv/">TV</a></h2>
          <p class="media-card__muted">Episode-level log and show counts.</p>

          <div class="media-card__latest">
            <h3>Latest episode</h3>
            {% if latestEp %}
              <div class="media-card__header">
                {% if latestEp.poster %}
                <img
                  src="{{ latestEp.poster }}"
                  alt="Poster for {{ latestEp.show }}"
                  loading="lazy"
                  class="media-card__poster media-card__poster-3-3"
                >
                {% endif %}
                <div>
                  <h4 class="media-card__title">
                    {% if latestEp.tmdbUrl %}
                    <a href="{{ latestEp.tmdbUrl }}" target="_blank" rel="noopener">{{ latestEp.show }}</a>
                    {% else %}
                      {{ latestEp.show }}
                    {% endif %}
                    {% if latestEp.year %}<span class="watch-muted"> ({{ latestEp.year }})</span>{% endif %}
                  </h4>
                  <div class="media-card__meta">
                    {% if latestEp.season %}
                    <span>Season {{ latestEp.season }} Episode {{ latestEp.episode }}</span>
                    {% endif %}
                    {% if latestEp.watchedOn %}
                    <span>Watched on: {{ latestEp.watchedOn | dateFilter }}</span>
                    {% endif %}
                    {% if latestEp.rating %}
                    <span>★ {{ latestEp.rating }}/5</span>
                    {% endif %}
                    {% if latestEp.rewatch %}
                    <span>Rewatch</span>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% else %}
              <p class="media-card__muted">No TV episodes logged yet.</p>
            {% endif %}
          </div>

          <div class="media-card__links">
            <a href="/logs/watching/tv/">Browse all TV →</a>
          </div>
        </div>
      </section>
    </div>

    {% include "components/tmdb-attribution.njk" %}
  </div>
  <div class="sidebar meta">
    <h3 class="heading">
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-stats" /></svg>
      <span>Stats</span>
    </h3>
    <p>I've watched a total of <strong>{{ watch.stats.totalMovies }}</strong> films, <strong>{{ watch.stats.totalEpisodes }}</strong> episodes</span> and <strong>{{ watch.stats.totalShows }}</strong> shows.</p>
  </div>
</div>
