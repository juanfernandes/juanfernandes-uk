---
layout: page
title: Television
permalink: /logs/watching/tv/
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A show-first view of what I’ve been watching, with seasons and episode history grouped together.</p>

    {% if watch.tvYears and watch.tvYears.length %}
    <div class="media-years">
      <span>Years:</span>
      {% for y in watch.tvYears %}
        {% if watch.tvByYear[y] %}
          <a href="/logs/watching/tv/{{ y }}/">{{ y }}</a>{% if not loop.last %} · {% endif %}
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    <div class="media-grid media-grid--2-col">
      {% for showId, bucket in watch.tvGrouped %}
        {% set latestSeason = 0 %}
        {% set latestEpisode = 0 %}
        {% set latestDate = "" %}
        {% set episodeCount = 0 %}
        {% set seasonCount = 0 %}
        {% set poster = "" %}
        {% set year = "" %}

        {% for seasonNum, episodes in bucket.seasons %}
          {% set seasonCount = seasonCount + 1 %}
          {% set episodeCount = episodeCount + (episodes | length) %}
          {% if episodes and episodes[0] %}
            {% if episodes[0].poster and not poster %}{% set poster = episodes[0].poster %}{% endif %}
            {% if episodes[0].year and not year %}{% set year = episodes[0].year %}{% endif %}
          {% endif %}
          {% for ep in episodes %}
            {% if ep.watchedOn > latestDate %}
              {% set latestDate = ep.watchedOn %}
              {% set latestSeason = ep.season %}
              {% set latestEpisode = ep.episode %}
            {% endif %}
          {% endfor %}
        {% endfor %}

        {% include "partials/media-card-details.njk" %}
      {% endfor %}
    </div>

    {% include "components/tmdb-attribution.njk" %}
  </div>
  <div class="sidebar meta">
    <h3 class="heading">All-time</h3>
    <p>I've watched a total of <strong>{{ watch.stats.totalEpisodes }}</strong> episodes and <strong>{{ watch.stats.totalShows }}</strong> shows.</p>
  </div>
</div>
