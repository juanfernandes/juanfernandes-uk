---
layout: page
title: Concerts
permalink: /logs/concerts/
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A log of the gigs I’ve been to — the dates, venues, and artists that made them memorable. There’s something different about hearing music live, and this page is a small archive of those nights and the places they happened.</p>

    {% set latestGig = concerts.entries[0] %}

    <div class="media-grid">
      <section class="media-card">
        <div class="media-card__body">
          <h2 class="media-card__heading">Most recent</h2>
          <p class="media-card__muted">The latest gig logged.</p>

          {% if latestGig %}
          <div class="media-card__latest">
            <p class="media-title">
              <strong>{{ latestGig.artists | join(", ") }}</strong> —
              <span class="media-card__muted">{{ latestGig.date | dateFilter }}</span>
            </p>
            <div class="media-card__meta">
              {% if latestGig.venue %}
              <span>{{ latestGig.venue }}{% if latestGig.city %}, {{ latestGig.city }}{% endif %}</span>
              {% endif %}
              {% if latestGig.country %}
              <span>{{ latestGig.country }}</span>
              {% endif %}
              {% if latestGig.links and latestGig.links.setlistFm %}
              <span><a href="{{ latestGig.links.setlistFm }}">Setlist.fm</a></span>
              {% endif %}
              {% if latestGig.links and latestGig.links.tickets %}
                <span><a href="{{ latestGig.links.tickets }}">Tickets</a></span>
              {% endif %}
              {% if latestGig.notes %}
                <span class="tag">has notes</span>
              {% endif %}
            </div>
          </div>
          {% else %}
            <p class="media-muted">No concerts logged yet.</p>
          {% endif %}
        </div>
      </section>

      <section class="media-card">
        <div class="media-card__body">
          <h2 class="media-card__heading">Browse by year</h2>
          <p class="media-card__muted">Jump to a year archive.</p>

          <div class="media-card__list">
            {% set years = concerts.years %}
            {% set base = "/logs/concerts" %}
            {% include "components/year-nav.njk" %}
          </div>
        </div>
      </section>
    </div>

    <h2 class="u-mt-2">All concerts</h2>

    <ul class="media-list">
      {% for gig in concerts.entries %}
        <li>
          <strong>{{ gig.artists | join(", ") }}</strong>
          <span class="media-muted">— {{ gig.date | dateFilter }}</span>
          <span class="media-muted">— {{ gig.venue }}{% if gig.city %}, {{ gig.city }}{% endif %}</span>
          {% if gig.links and gig.links.setlistFm %}
            <span class="media-muted"> · <a href="{{ gig.links.setlistFm }}">setlist</a></span>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="sidebar meta">
    <h3 class="heading">All-time</h3>
    <p>I've been to a total of <strong>{{ concerts.stats.totalConcerts }}</strong> concerts, to see <strong>{{ concerts.stats.totalArtists }}</strong> artists at <strong>{{ concerts.stats.totalVenues }}</strong> different venues.
    </p>
  </div>
</div>
