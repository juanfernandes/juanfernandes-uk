---
layout: page
pagination:
  data: concerts.years
  size: 1
  alias: year
permalink: "/logs/concerts/year/{{ year }}/"
eleventyComputed:
  title: "Concerts — {{ year }}"
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<h2>Concerts attended in {{ year }}</h2>

<ul>
  {% for gig in (concerts.byYear[year] or []) %}
    <li>
      <strong>{{ gig.artists | join(", ") }}</strong> — {{ gig.date | dateFilter }}
      — {{ gig.venue }}, {{ gig.city }}
    </li>
  {% endfor %}
</ul>
