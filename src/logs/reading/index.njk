--- 
title: "Reading"
layout: "page"
tags:
  - search
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

{% set currentBook = reading.currentBooks[0] %}
{% set latestFinishedBook = reading.latestFinishedBook %}
{% set latestFinishedArticle = reading.latestFinishedArticle %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A running log of the books and articles I’ve read — from longer reads to quick finds, all captured in one place.</p>

    <div class="dash-grid dash-grid--2-col">
      <section class="dash-card">
        <div class="dash-card__content">
          <div>
            <h2 class="dash-card__title"><a href="/logs/reading/books/">Books</a></h2>
            <p class="dash-card__muted">A running log of the books I’ve read, bringing together titles that have informed my thinking, broadened my perspective, or simply been enjoyable to explore.</p>
          </div>

          <div class="dash-card__latest">
            <h3>Currently reading</h3>
            {% if currentBook %}
              <div class="dash-card__header">
                {% if currentBook.img %}
                <img 
                  src="{{ site.cloudinary_url }}w_180,h_276,f_auto/books/{{ currentBook.img }}"
                  alt="{{ currentBook.title }}"
                  width="180"
                  height="276"
                  loading="lazy"
                  class="media-card__poster media-card__poster-3-3"
                >
                {% endif %}
                <div>
                  <h4 class="dash-card__title">
                    {% if currentBook.url %}
                      <a href="{{ currentBook.url }}" target="_blank" rel="noopener">{{ currentBook.title }}</a>
                    {% else %}
                      {{ currentBook.title }}
                    {% endif %}
                  </h4>

                  <div class="dash-card__meta">
                    {% if currentBook.author %}
                    <span>{{ currentBook.author }}</span>
                    {% endif %}
                    {% if currentBook.subtitle %}
                    <span>{{ currentBook.subtitle }}</span>
                    {% endif %}
                  </div>

                  {% if currentBook.notes %}
                    <p class="dash-card__muted">{{ currentBook.notes }}</p>
                  {% endif %}
                </div>
              </div>
            {% else %}
              <p class="dash-card__muted">Nothing marked as currently reading.</p>
            {% endif %}

            {% if latestFinishedBook %}
            <h3 class="u-mt-2">Latest finished book</h3>
            <div>
              <h4 class="dash-card__title">
                {% if latestFinishedBook.url %}
                  <a href="{{ latestFinishedBook.url }}" target="_blank" rel="noopener">{{ latestFinishedBook.title }} - {% if latestFinishedBook.author %}{{ latestFinishedBook.author }}{% endif %}</a>
                {% else %}
                  {{ latestFinishedBook.title }} - {% if latestFinishedBook.author %}{{ latestFinishedBook.author }}{% endif %}
                {% endif %}
              </h4>

              <div class="dash-card__meta">
                {% if latestFinishedBook.yearRead %}
                  <span>Finished in {{ latestFinishedBook.yearRead }}</span>
                {% endif %}
              </div>
            </div>
            {% else %}
              <p>No finished books logged yet.</p>
            {% endif %}
          </div>

          <div class="dash-card__links">
            <a href="/logs/reading/books/">Browse all books →</a>
          </div>
        </div>
      </section>

      <section class="dash-card">
        <div class="dash-card__content">
          <div>
            <h2 class="dash-card__title"><a href="/logs/reading/articles/">Articles</a></h2>
            <p class="dash-card__muted">Saved reading from around the web, bringing together articles and resources that have informed my thinking, sparked ideas, or been worth returning to later.</p>
          </div>

          <div class="dash-card__latest">
            <h3>Latest article</h3>
            {% if latestFinishedArticle %}
            <div>
              <h4 class="dash-card__title">
                {% if latestFinishedArticle.url %}
                  <a href="{{ latestFinishedArticle.url }}" target="_blank" rel="noopener">{{ latestFinishedArticle.title }}</a>
                {% else %}
                  {{ latestFinishedArticle.title }}
                {% endif %}
              </h4>

              <div class="dash-card__meta">
                {% if latestFinishedArticle.date %}
                  <span>Read on the {{ latestFinishedArticle.date | dateFilter }}</span>
                {% endif %}
              </div>

              {% if latestFinishedArticle.content %}
                <p class="u-mt-1">{{ latestFinishedArticle.content }}</p>
              {% endif %}
            </div>
            {% else %}
            <p>No articles logged yet.</p>
            {% endif %}
          </div>

          <div class="dash-card__links">
            <a href="/logs/reading/articles/">Browse all articles →</a>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div class="sidebar meta">
      <h3 class="heading">
        <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-stats" /></svg>
        <span>Stats</span>
      </h3>
    <p>I’ve logged a total of <strong>{{ reading.stats.finishedBooks }}</strong> books, <strong>{{ reading.stats.finishedArticles }}</strong> articles, and I currently have<strong>{{ reading.stats.currentlyReading }}</strong> book {% if reading.stats.currentlyReading != 1 %}s{% endif %} on the go.</p>
  </div>
</div>
