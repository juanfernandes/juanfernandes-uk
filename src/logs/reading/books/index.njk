--- 
title: "Books"
layout: "page"
tags:
  - search
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A record of the books I’ve read and the ones I’m currently working through. Some stay with me longer than others, but this log keeps a timeline of what I’ve spent time reading.</p>

    <div id="current">
      <h2 class="section-heading">Currently Reading</h2>
      {% set currentBook = books | findCurrentBook %}
      <div class="bookshelf">
        {% if currentBook %}
        <div class="book">
          <a href="{{ currentBook.url }}" aria-label="{{ currentBook.title }}"><img src="{{ site.cloudinary_url }}w_180,h_276,f_auto/books/{{ currentBook.img }}" alt="{{ currentBook.title }}" width="180" height="276"></a>
          <div class="details">
            <h3>{{ currentBook.title }}</h3>
            {% if currentBook.subtitle %}
            <span class="subtitle">{{ currentBook.subtitle }}</span>
            {% endif %}
            <span class="author">{{ currentBook.author }}</span>
          </div>
        </div>
        {% else %}
        <p>No current book found.</p>
        {% endif %}
      </div>
    </div>

    <div id="read">
      <h2 class="section-heading">Read</h2>
      {% for yearRead, book in books | groupby("yearRead") | dictsort | reverse %}
      {% if yearRead %}
        <h3 id="year-{{ yearRead }}">{{ yearRead }}</h3>
        <div class="bookshelf">
          {% for book in book | sort(attribute='title') %}
          <div class="book">
            <a href="{{ book.url }}" aria-label="{{ book.title }}"><img src="{{ site.cloudinary_url }}w_180,h_276,f_auto/books/{{ book.img }}" alt="{{ book.title }}" width="180" height="276"></a>
            <div class="details">
              <h3>{{ book.title }}</h3>
              {% if book.subtitle %}<span class="subtitle">{{ book.subtitle }}</span>{% endif %}
              <span class="author">{{ book.author }}</span>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
      {% endfor %}
    </div>

    <div id="want-to-read">
      <h2 class="section-heading">Want to Read</h2>
      <div class="bookshelf">
      {% for book in books | sort(attribute='title') %}
        {% if book.status == "toRead" %}
          <div class="book">
            <a href="{{ book.url }}" aria-label="{{ book.title }}"><img src="{{ site.cloudinary_url }}w_180,h_276,f_auto/books/{{ book.img }}" alt="{{ book.title }}" width="180" height="276"></a>
            <div class="details">
              <h3>{{ book.title }}</h3>
              {% if book.subtitle %}<span class="subtitle">{{ book.subtitle }}</span>{% endif %}
              <span class="author">{{ book.author }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      </div>
    </div>

    <div id="summarised">
      <h2 class="section-heading">Summaries</h2>
      {% for yearRead, book in summaries | groupby("yearRead") | dictsort | reverse %}
      {% if yearRead %}
        <h3>{{ yearRead }}</h3>
        <div class="bookshelf u-mb-0">
          {% for book in summaries | sort(attribute='title') %}
          <div class="book">
            <a href="{{ book.url }}" aria-label="{{ book.title }}"><img src="{{ site.cloudinary_url }}w_180,h_276,f_auto/books/{{ book.img }}" alt="{{ book.title }}" width="180" height="276"></a>
            <div class="details">
              <h3>{{ book.title }}</h3>
              {% if book.subtitle %}<span class="subtitle">{{ book.subtitle }}</span>{% endif %}
              <span class="author">{{ book.author }}</span>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="sidebar meta">
    <h3 class="heading">All-time Stats</h3>
    <p>I'm currently reading <strong>{{ reading.stats.currentlyReading }}</strong> book, have read <strong>{{ reading.stats.finished }}</strong> books and have <strong>{{ reading.stats.toRead }}</strong> to read.</p>

    <h3 class="heading">Section Navigation</h3>
    <nav>
      <ul class="u-flex u-flex-col">
        <li><a href="#read">Read</a></li>
        <li><a href="#want-to-read">Want To Read</a></li>
        <li><a href="#summarised">Summaries</a></li>
        <li><a href="#current">Currently Reading</a></li>
      </ul>
    </nav>
    
    {% if reading.years and reading.years.length %}
    <h3 class="heading">Years</h3>
    <p>
      {% for y in reading.years %}
        <a href="/logs/reading/#year-{{ y }}">{{ y }}</a>{% if not loop.last %} · {% endif %}
      {% endfor %}
    </p>
    {% endif %}
  </div>
</div>
