--- 
title: "Books"
layout: "page"
class: "u-content-gap"
tags:
  - search
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A record of the books I’ve read and the ones I’m currently working through. Some stay with me longer than others, but this log keeps a timeline of what I’ve spent time reading.</p>

    <div id="current">
      <h2 class="section-heading">Currently Reading</h2>
      {% set currentBook = books | findCurrentBook %}
      <div class="media-grid u-mb-2">
        {% if currentBook %}
        <div class="media-card">
          <div>
          {% if currentBook.img %}
            <img class="media-card__poster media-card__poster-3-3" src="{{ site.cloudinary_url }}w_342,h_512,f_auto/books/{{ currentBook.img }}" alt="{{ currentBook.title }}" loading="lazy">
          {% else %}
          <div class="media-card__meta">
            <span>No cover</span>
          </div>
          {% endif %}
          </div>

          <div class="media-card__body">
            <h3 class="media-card__title">
              {% if currentBook.url %}
              <a href="{{ currentBook.url }}" target="_blank" rel="noopener">{{ currentBook.title }}</a>
              {% else %}
              {{ currentBook.title }}
              {% endif %}
            </h3>
            {% if currentBook.subtitle %}<h4>{{ currentBook.subtitle }}</h4>{% endif %}

            <div class="media-card__meta">
              {% if currentBook.author %}<span class="author">{{ currentBook.author }}</span>{% endif %}
            </div>
          </div>
        </div>
        {% else %}
        <p>No current book found.</p>
        {% endif %}
      </div>
    </div>

    <div id="read">
      <h2 class="section-heading">Read</h2>
      {% for yearRead, book in books | groupby("yearRead") | dictsort | reverse %}
      {% if yearRead %}
        <h3 id="year-{{ yearRead }}">{{ yearRead }}</h3>
        <div class="media-grid u-mb-2">
          {% for book in book | sort(attribute='title') %}
          <div class="media-card">
            <div>
            {% if book.img %}
              <img class="media-card__poster media-card__poster-3-3" src="{{ site.cloudinary_url }}w_342,h_512,f_auto/books/{{ book.img }}" alt="{{ book.title }}" loading="lazy">
            {% else %}
            <div class="media-card__meta">
              <span>No cover</span>
            </div>
            {% endif %}
            </div>

            <div class="media-card__body">
              <h3 class="media-card__title">
                {% if book.url %}
                <a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>
                {% else %}
                {{ book.title }}
                {% endif %}
              </h3>
              {% if book.subtitle %}<h4>{{ book.subtitle }}</h4>{% endif %}

              <div class="media-card__meta">
                {% if book.author %}<span class="author">{{ book.author }}</span>{% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
      {% endfor %}
    </div>

    <div id="want-to-read">
      <h2 class="section-heading">Want to Read</h2>
      <div class="media-grid u-mb-2">
      {% for book in books | sort(attribute='title') %}
        {% if book.status == "toRead" %}
        <div class="media-card">
          <div>
          {% if book.img %}
            <img class="media-card__poster media-card__poster-3-3" src="{{ site.cloudinary_url }}w_342,h_512,f_auto/books/{{ book.img }}" alt="{{ book.title }}" loading="lazy">
          {% else %}
          <div class="media-card__meta">
            <span>No cover</span>
          </div>
          {% endif %}
          </div>

          <div class="media-card__body">
            <h3 class="media-card__title">
              {% if book.url %}
              <a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>
              {% else %}
              {{ book.title }}
              {% endif %}
            </h3>
            {% if book.subtitle %}<h4>{{ book.subtitle }}</h4>{% endif %}

            <div class="media-card__meta">
              {% if book.author %}<span class="author">{{ book.author }}</span>{% endif %}
            </div>
          </div>
        </div>
        {% endif %}
      {% endfor %}
      </div>
    </div>

    <div id="summarised">
      <h2 class="section-heading">Summaries</h2>
      {% for yearRead, book in summaries | groupby("yearRead") | dictsort | reverse %}
      {% if yearRead %}
        <h3>{{ yearRead }}</h3>
        <div class="media-grid u-mb-2">
          {% for book in summaries | sort(attribute='title') %}
          <div class="media-card">
            <div>
            {% if book.img %}
              <img class="media-card__poster media-card__poster-3-3" src="{{ site.cloudinary_url }}w_342,h_512,f_auto/books/{{ book.img }}" alt="{{ book.title }}" loading="lazy">
            {% else %}
            <div class="media-card__meta">
              <span>No cover</span>
            </div>
            {% endif %}
            </div>

            <div class="media-card__body">
              <h3 class="media-card__title">
                {% if book.url %}
                <a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>
                {% else %}
                {{ book.title }}
                {% endif %}
              </h3>
              {% if book.subtitle %}<h4>{{ book.subtitle }}</h4>{% endif %}

              <div class="media-card__meta">
                {% if book.author %}<span class="author">{{ book.author }}</span>{% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  
  <div class="sidebar meta">
    <h3 class="heading">
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-book" /></svg>
      <span>Reading</span>
    </h3>
    <nav>
      <ul class="u-flex u-flex-col">
        <li><a href="/logs/reading/books/">Books</a></li>
        <li><a href="/logs/reading/articles/">Articles</a></li>
      </ul>
    </nav>

    <div class="u-mt-2">
      <h3 class="heading">
        <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-directions" /></svg>
        <span>In this section</span>
      </h3>
      <nav>
        <ul class="u-flex u-flex-col">
          <li><a href="#read">Read</a></li>
          <li><a href="#want-to-read">Want To Read</a></li>
          <li><a href="#summarised">Summaries</a></li>
          <li><a href="#current">Currently Reading</a></li>
        </ul>
      </nav>
    </div>
    
    {% if reading.years and reading.years.length %}
    <div class="u-mt-2">
      <h3 class="heading">
        <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-cal-alt" /></svg>
        <span>Years</span>
      </h3>
      <p>
        {% for y in reading.years %}
          <a href="/logs/reading/books/#year-{{ y }}">{{ y }}</a>{% if not loop.last %} · {% endif %}
        {% endfor %}
      </p>
    </div>
    {% endif %}
    <div class="u-mt-2">
      <h3 class="heading">
        <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-stats" /></svg>
        <span>Stats</span>
      </h3>
      <p>I'm currently reading <strong>{{ reading.stats.currentlyReading }}</strong> book, have read <strong>{{ reading.stats.finished }}</strong> books and have <strong>{{ reading.stats.toRead }}</strong> to read.</p>
    </div>
  </div>
</div>
