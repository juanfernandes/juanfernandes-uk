---
layout: page
title: Listening
bodyClass: music
permalink: /logs/listening/
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

{% set latestTrack = lastfmRecent.latestTrack or null %}

<div class="grid grid-9-3 gap-2">
  <div>
    <p class="lead">A snapshot of the music I’ve been listening to recently. Pulled from my listening history, it highlights the artists, albums, and tracks that have been in regular rotation.</p>

    {% if lastfmRecent.error %}
      <p><strong>{{ lastfmRecent.error }}</strong></p>
    {% else %}

      <div class="watch-grid">
        <section class="watch-card">
          <h2><a href="/logs/listening/tracks/">Tracks</a></h2>
          <p class="watch-muted">Latest listening and the tracks I’ve had on repeat this week.</p>

          <div class="watch-latest">
            <h3 class="watch-title">Latest track</h3>

            {% if lastfmRecent.latestTrack %}
              <div class="watch-row">

                {% if lastfmRecent.latestTrack.image %}
                <div class="watch-poster">
                  <img
                    src="{{ lastfmRecent.latestTrack.image }}"
                    alt="{{ lastfmRecent.latestTrack.album }}"
                    loading="lazy"
                  >
                </div>
                {% endif %}

                <div>
                  <h4 class="watch-title">
                    <a href="{{ lastfmRecent.latestTrack.url }}" target="_blank" rel="noopener">
                      {{ lastfmRecent.latestTrack.name }}
                    </a>
                  </h4>

                  <div class="watch-meta">
                    <span>{{ lastfmRecent.latestTrack.artist }}</span>

                    {% if lastfmRecent.latestTrack.album %}
                      <span>{{ lastfmRecent.latestTrack.album }}</span>
                    {% endif %}

                    {% if lastfmRecent.latestTrack.isNowPlaying %}
                      <span class="watch-badge">Now playing</span>
                    {% endif %}
                  </div>
                </div>

              </div>
            {% else %}
              <p class="watch-muted">No recent tracks available.</p>
            {% endif %}
          </div>

{#           <ul class="watch-list">
            {% for t in lastfmRecent.weekTopTracks | head(8) %}
              <li>
                <span class="list-item-name">{{ t.name }} — {{ t.artist }}</span>
                <span class="watch-muted"> · {{ t.plays }} plays</span>
              </li>
            {% endfor %}
          </ul> #}

          <div class="watch-links">
            <a href="/logs/listening/tracks/">Browse all tracks →</a>
          </div>
        </section>

        <section class="watch-card">
          <h2><a href="/logs/listening/artists/">Artists</a></h2>
          <p class="watch-muted">The artists I’ve been returning to most over the last week.</p>

          <div class="watch-latest">
            <h3 class="watch-title">Top artist this week</h3>

            {% set topArtist = lastfmRecent.weekTopArtistsTop10[0] %}

            {% if topArtist %}
              <div class="watch-row">
                {% if topArtist.image %}
                  <div class="watch-poster">
                    <img
                      src="{{ topArtist.image }}"
                      alt="{{ topArtist.name }}"
                      loading="lazy"
                    >
                  </div>
                {% endif %}

                <div>
                  <h4 class="watch-title">
                    {% if topArtist.url %}
                      <a href="{{ topArtist.url }}" target="_blank" rel="noopener">{{ topArtist.name }}</a>
                    {% else %}
                      {{ topArtist.name }}
                    {% endif %}
                  </h4>

                  <div class="watch-meta">
                    <span>{{ topArtist.plays }} plays this week</span>
                  </div>
                </div>
              </div>
            {% else %}
              <p class="watch-muted">No top artist available this week.</p>
            {% endif %}
          </div>

          <div class="watch-links">
            <a href="/logs/listening/artists/">Browse all artists →</a>
          </div>
        </section>

        <section class="watch-card">
          <h2><a href="/logs/listening/albums/">Albums</a></h2>
          <p class="watch-muted">The album that’s had the heaviest rotation this week.</p>

          {% set topAlbum = lastfmRecent.weekTopAlbumsTop10[0] %}

          <div class="watch-latest">
            <h3 class="watch-title">Top album this week</h3>
            {% if topAlbum %}
              <div class="watch-row">

                {% if topAlbum.image %}
                  <div class="watch-poster">
                    <img
                      src="{{ topAlbum.image }}"
                      alt="{{ topAlbum.album }} by {{ topAlbum.artist }}"
                      loading="lazy"
                    >
                  </div>
                {% endif %}

                <div>
                  <h3 class="watch-title">
                    {% if topAlbum.url %}
                      <a href="{{ topAlbum.url }}" target="_blank" rel="noopener">
                        {{ topAlbum.album }}
                      </a>
                    {% else %}
                      {{ topAlbum.album }}
                    {% endif %}
                  </h3>

                  <div class="watch-meta">
                    <span>{{ topAlbum.artist }}</span>
                    <span>{{ topAlbum.plays }} plays this week</span>
                  </div>

                </div>

              </div>

            {% else %}
              <p class="watch-muted">No album data available this week.</p>
            {% endif %}

          </div>

          <div class="watch-links">
            <a href="/logs/listening/albums/">Browse all albums →</a>
          </div>
        </section>
      </div>
    {% endif %}
  </div>

  <div class="sidebar meta">
    {% if lastfmRecent.weekSummary %}
      <h3 class="heading">This week</h3>
      <p>
        I’ve listened to
        <strong>{{ lastfmRecent.weekSummary.artists }}</strong> artists,
        <strong>{{ lastfmRecent.weekSummary.albums }}</strong> albums and
        <strong>{{ lastfmRecent.weekSummary.tracks }}</strong> tracks this week.
        {% if lastfmRecent.weekSummary.genres and lastfmRecent.weekSummary.genres.length %}
          Most of that has been {{ lastfmRecent.weekSummary.genres | join(", ") }}.
        {% endif %}
      </p>
    {% endif %}

    <h3 class="heading">All-time</h3>
    <ul class="list-style-none">
      <li><strong>{{ musicAllTimeStats.artists }}</strong> artists</li>
      <li><strong>{{ musicAllTimeStats.albums }}</strong> albums</li>
      <li><strong>{{ musicAllTimeStats.tracks }}</strong> tracks</li>
    </ul>
  </div>
</div>
