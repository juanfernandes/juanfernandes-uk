---
layout: page
title: Albums
bodyClass: music
class: u-content-gap
pagination:
  data: lastfmRecent.weekTopAlbums
  size: 50
  alias: items
permalink: "/logs/listening/albums/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
{% set section = section or "logs" %}
{% include "components/dash-nav.njk" %}

<div class="grid grid-9-3 gap-2">
  <div>
    <h2>All Albums (this week)</h2>
    <nav>
      <div class="nav--inline">
        <span>← <a href="/logs/listening/">Back to listening</a></span>
      </div>
    </nav>

    <ol class="music-list" start="{{ pagination.pageNumber * pagination.size + 1 }}">
      {% for a in items %}
        <li class="list-item">{{ a.album }} - {{ a.artist }} · <span class="tag">{{ a.plays }} plays</span></li>
      {% endfor %}
    </ol>

    {% include 'components/pagination.njk' %}
  </div>

  <div class="sidebar meta">
    <h3 class="heading">
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-music" /></svg>
      <span>Listening</span>
    </h3>
    <nav>
      <ul class="u-flex u-flex-col">
        <li><a href="/logs/listening/albums/">Albums</a></li>
        <li><a href="/logs/listening/tracks/">Tracks</a></li>
        <li><a href="/logs/listening/artists/">Artists</a></li>
      </ul>
    </nav>

    {% if lastfmRecent.weekSummary or musicAllTimeStats.album %}
    <div class="u-mt-2">
      <h3 class="heading">
        <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-stats" /></svg>
        <span>Stats</span>
      </h3>
      <p>This week I’ve listened to <strong>{{ lastfmRecent.weekSummary.albums }}</strong> albums.</p>
      <p>I've listened to a total of <strong>{{ musicAllTimeStats.albums }}</strong> albums.</p>
    </div>
    {% endif %}
  </div>
</div>
