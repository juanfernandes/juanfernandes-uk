    </li>
    <li{% if current == '/collections/games/' %} class="active"{% endif %}>
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-controller" /></svg>
      <a href="/collections/games/">Games</a>
    </li>
    <li{% if current == '/collections/music/' %} class="active"{% endif %}>
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-disc" /></svg>
      <a href="/collections/music/">Music</a>
    </li>
    <li{% if current == '/collections/funko-pops/' %} class="active"{% endif %}>
      <svg aria-hidden="true" width="24" height="24"><use xlink:href="#svg-box" /></svg>
      <a href="/collections/funko-pops/">Funko Pops</a>
    </li>
    {% endif %}
  </ul>
