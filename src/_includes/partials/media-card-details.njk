    <details class="media-card">
      <summary class="media-card__header">
        {% if bucket.poster %}
        <div class="media-card__poster">
          <img src="{{ bucket.poster }}" alt="Poster for {{ bucket.show }}" loading="lazy">
        </div>
        {% endif %}

        <div class="media-card__body">
          <h3 class="media-card__title">
            {% if bucket.tmdbUrl %}
              <a href="{{ bucket.tmdbUrl }}" target="_blank" rel="noopener">{{ bucket.show }}</a>
            {% else %}
              {{ bucket.show }}
            {% endif %}
            {% if year %}({{ year }}){% endif %}
          </h3>

          <div class="media-card__meta">
            <span><strong>{{ seasonCount }}</strong> Seasons · <strong>{{ episodeCount }}</strong> episodes watched</span>
          {% if latestDate %}
            <span>Latest watched: Season {{ latestSeason }} Episode {{ latestEpisode }}</span>
            <span>Watched on: {{ latestDate | dateFilter }}</span>
          {% endif %}
          </div>
        </div>
      </summary>

      <div class="media-card__list">
        {% for seasonNum, episodes in bucket.seasons %}
          <details class="media-card__list-item">
            <summary>Season {{ seasonNum }}</summary>
            <ul>
              {% for ep in episodes %}
                <li class="media-card__meta">
                  <span>Season {{ ep.season }} Episode {{ ep.episode }} — {{ ep.watchedOn | dateFilter }}</span>
                  {% if ep.rating %}<span>★ {{ ep.rating }}/5</span>{% endif %}
                  {% if ep.rewatch %}<span>Rewatch</span>{% endif %}
                </li>
              {% endfor %}
            </ul>
          </details>
        {% endfor %}
      </div>
    </details>
